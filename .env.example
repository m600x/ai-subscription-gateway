# --- required ---
# Key clients (e.g. Open WebUI) must present as: Authorization: Bearer <CLIENT_API_KEY>
CLIENT_API_KEY=change-me
# Long-lived subscription token from `claude setup-token` (sk-ant-oat01-...). TTL 1 year, no auto-renew.
ANTHROPIC_OAUTH_TOKEN=sk-ant-oat01-...

# --- optional (defaults shown) ---
PORT=8000
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_VERSION=2023-06-01
# ANTHROPIC_BETA=oauth-2025-04-20
# SPOOF_SYSTEM_PROMPT=You are Claude Code, Anthropic's official CLI for Claude.
# USER_AGENT=claude-cli/1.0.0 (external, cli)
MODELS=claude-fable-5,claude-opus-4-8,claude-sonnet-5
DEFAULT_MODEL=claude-sonnet-5
DEFAULT_MAX_TOKENS=8192
ENABLE_WEB_SEARCH=false
# Models supporting adaptive thinking (effort ladder low|medium|high|xhigh|max
# via the reasoning_effort parameter).
THINKING_MODELS=claude-fable-5,claude-opus-4-8,claude-sonnet-5
# Models that cannot disable thinking ("off" is silently ignored).
THINKING_ALWAYS_ON_MODELS=claude-fable-5
# Models that think by default ("off" sends an explicit thinking disable).
THINKING_DEFAULT_ON_MODELS=claude-sonnet-5
# thinking.display: "summarized" streams readable thinking (reasoning_content
# in clients); "omitted" hides it.
THINKING_DISPLAY=summarized
REQUEST_TIMEOUT_SECONDS=600
MAX_RETRIES=2
LOG_LEVEL=info

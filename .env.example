# --- required ---
# Key clients (e.g. Open WebUI) must present as: Authorization: Bearer <CLIENT_API_KEY>
CLIENT_API_KEY=change-me
# Long-lived subscription token from `claude setup-token` (sk-ant-oat01-...). TTL 1 year, no auto-renew.
ANTHROPIC_OAUTH_TOKEN=sk-ant-oat01-...

# --- optional (defaults shown) ---
PORT=8000
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_VERSION=2023-06-01
# ANTHROPIC_BETA=oauth-2025-04-20
# SPOOF_SYSTEM_PROMPT=You are Claude Code, Anthropic's official CLI for Claude.
# USER_AGENT=claude-cli/1.0.0 (external, cli)
MODELS=claude-fable-5,claude-opus-4-8,claude-sonnet-5
DEFAULT_MODEL=claude-sonnet-5
DEFAULT_MAX_TOKENS=8192
ENABLE_WEB_SEARCH=false
# Default thinking budget for PLAIN (un-suffixed) model ids. 0 = off (fast).
# Per-request control comes from the -thinking alias and reasoning_effort.
MAX_THINKING_TOKENS=0
# Base models that accept an explicit thinking budget -> advertised with a
# "-thinking" alias and honoring reasoning_effort. Omit models whose thinking
# is always silent server-side (e.g. Fable).
THINKING_MODELS=claude-opus-4-8,claude-sonnet-5
# reasoning_effort low|medium|high -> thinking budget (tokens).
THINKING_BUDGET_LOW=2048
THINKING_BUDGET_MEDIUM=8192
THINKING_BUDGET_HIGH=16384
REQUEST_TIMEOUT_SECONDS=600
MAX_RETRIES=2
LOG_LEVEL=info

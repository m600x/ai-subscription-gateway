# --- required ---
# Key clients (e.g. Open WebUI) must present as: Authorization: Bearer <CLIENT_API_KEY>
CLIENT_API_KEY=change-me

# --- providers (configure at least one; each is enabled only if its creds are set) ---
# Anthropic (Claude subscription): long-lived token from `claude setup-token`
# (sk-ant-oat01-...). TTL 1 year, no auto-renew.
ANTHROPIC_OAUTH_TOKEN=sk-ant-oat01-...
# OpenAI (ChatGPT/Codex subscription): refresh token from `./server login`.
# The wrapper refreshes the short-lived access token itself, in-memory.
# OPENAI_REFRESH_TOKEN=

# --- model registry ---
# Path to the model list + per-model reasoning efforts (source of truth for
# what is advertised and how each model reasons).
# MODELS_CONFIG=models.json
# Used when a request omits the model. Defaults to the first models.json entry
# whose provider is enabled.
# DEFAULT_MODEL=
DEFAULT_MAX_TOKENS=8192

# --- optional: Anthropic (defaults shown) ---
PORT=8000
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_VERSION=2023-06-01
# ANTHROPIC_BETA=oauth-2025-04-20
# SPOOF_SYSTEM_PROMPT=You are Claude Code, Anthropic's official CLI for Claude.
# USER_AGENT=claude-cli/1.0.0 (external, cli)
ENABLE_WEB_SEARCH=false
# thinking.display: "summarized" streams readable thinking (reasoning_content
# in clients); "omitted" hides it.
THINKING_DISPLAY=summarized

# --- optional: OpenAI/Codex (defaults shown) ---
# OPENAI_BASE_URL=https://chatgpt.com/backend-api/codex
# OPENAI_AUTH_ISSUER=https://auth.openai.com
# OPENAI_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann
# OPENAI_ORIGINATOR=codex_cli_rs
# OPENAI_USER_AGENT=codex_cli_rs/0.1.0 (external; wrapper)
# Optional base instructions sent as the Responses `instructions` field.
# OPENAI_BASE_INSTRUCTIONS=
# Advanced: use a static access token instead of a refresh token (won't auto-renew).
# OPENAI_ACCESS_TOKEN=
# OPENAI_ACCOUNT_ID=

# --- shared ---
REQUEST_TIMEOUT_SECONDS=600
MAX_RETRIES=2
LOG_LEVEL=info
